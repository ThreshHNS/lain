OPENROUTER_API_KEY=your-openrouter-api-key
LAIN_AGENT_LLM_PROVIDER=openrouter
LAIN_AGENT_MODEL=openai/gpt-4.1-mini
LAIN_AGENT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LAIN_AGENT_TEMPERATURE=0.2
LAIN_AGENT_MAX_TOKENS=4000
LAIN_AGENT_PIPELINE_MAX_RETRIES=2
# Optional override if you run the service from outside the monorepo.
# LAIN_AGENT_REPO_ROOT=/absolute/path/to/lain
